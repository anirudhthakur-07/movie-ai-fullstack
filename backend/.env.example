# Server
PORT=5000

# Database — MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# Security — JWT signing secret (minimum 32 characters)
JWT_SECRET=<your_secure_random_passphrase_min_32_chars>

# External APIs — TMDB v3 API key (free at themoviedb.org)
TMDB_API_KEY=<your_tmdb_v3_api_key>
